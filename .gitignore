# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
ENV/
*.egg-info/
dist/
build/

# Database
*.db
*.sqlite
*.sqlite3

# Environment
.env
.env.local
.env.production

# Photo uploads (local storage, not in git)
server/static/uploads/*
!server/static/uploads/.gitkeep

# Runtime user content (lives on the box, not in git)
server/static/photos/
server/static/covers/

# Served OTA firmware images (binaries, served from the box only)
server/static/firmware/

# Runtime secret
server/.csrf_secret

# Archives (don't commit zips dropped into the repo; keep the tracked wake-word sample)
*.zip
!wake-word/hey_polly_samples.zip

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Audio test files
*.wav
*.mp3
*.raw
!wake-word/positive/*.wav
!wake-word/negative/*.wav
!server/static/sounds/*.wav

# Models (general)
*.tflite
*.onnx
*.pt
*.pth
# Keep our trained wake word model
!wake-word/hey_polly.onnx
!wake-word/hey_polly.onnx.data

# Arduino build
firmware/polly-esp32/build/
firmware/polly-esp32/*.elf
firmware/polly-esp32/*.bin

# Temp files
tmp/
temp/
*.tmp

# ESP-IDF build artifacts
firmware/polly-esp32/build/
firmware/polly-esp32/sdkconfig
firmware/polly-esp32/sdkconfig.old
firmware/polly-esp32/.cache/

# Porcupine library and models (download separately)
firmware/polly-esp32/components/porcupine/lib/*.a
firmware/polly-esp32/components/porcupine/models/*.ppn
!firmware/polly-esp32/components/porcupine/lib/README.md
!firmware/polly-esp32/components/porcupine/models/README.md

# ESP-IDF build artifacts (polly-s3-wakeword)
firmware/polly-s3-wakeword/build/
firmware/polly-s3-wakeword/sdkconfig
firmware/polly-s3-wakeword/sdkconfig.old
firmware/polly-s3-wakeword/.cache/
firmware/polly-s3-wakeword/managed_components/
firmware/polly-s3-wakeword/dependencies.lock

# ESPHome
firmware/polly-esp32-esphome/secrets.yaml
firmware/polly-esp32-esphome/.esphome/
firmware/polly-esp32-esphome/*.bin

# Claude Code
.claude/

# Piper sample generator (separate git repo)
piper-sample-generator/

# Windows artifacts
nul

# KiCad backups and broken-name exports
hardware/wi_barbell-attachments/polly_pcb-backups/
hardware/wi_barbell-attachments/${polly_pcb}.csv

# Stale duplicate pos exports (canonical copies live in hardware/polly-board/)
hardware/polly_pcb-top-pos.csv
hardware/polly_pcb-bottom-pos.csv
hardware/wi_barbell-attachments/polly_pcb-top-pos.csv
hardware/wi_barbell-attachments/polly_pcb-bottom-pos.csv

# KiCad ephemeral / regenerated artifacts
hardware/**/fp-info-cache
hardware/**/replicate_layout.log
hardware/**/*.kicad_prl
